{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "automerge": true,
  "automergeType": "branch",
  "customManagers": [
    {
      "customType": "regex",
      "datasourceTemplate": "node",
      "depNameTemplate": "node",
      "managerFilePatterns": ["/^Dockerfile$/"],
      "matchStrings": ["FROM node:(?<currentValue>.*?)-(alpine|slim)\\n"],
      "versioningTemplate": "node"
    },
    {
      "customType": "regex",
      "datasourceTemplate": "deb",
      "managerFilePatterns": [
        "/\\.github/workflows/.*\\.ya?ml$/",
        "/^Dockerfile$/"
      ],
      "matchStrings": [
        "#\\s+renovate:\\s+datasource=deb(?:\\s+distro=(?<distro>\\S+))?\\s+depName=(?<depName>\\S+)\\s+suite=(?<suite>\\S+)\\s+\\w+_\\w+:\\s+(?<currentValue>[^\\n]+)",
        "#\\s+renovate:\\s+datasource=deb(?:\\s+distro=(?<distro>\\S+))?\\s+depName=(?<depName>\\S+)\\s+suite=(?<suite>\\S+)\\s+ENV\\s+\\S+_VERSION=\"(?<currentValue>[^\"]+)\""
      ],
      "registryUrlTemplate": "https://{{#if (eq distro 'ubuntu')}}archive.ubuntu.com/ubuntu{{else}}deb.debian.org/debian{{/if}}?suite={{suite}}&components=main,multiverse,restricted,universe&binaryArch=amd64"
    },
    {
      "customType": "regex",
      "datasourceTemplate": "deb",
      "managerFilePatterns": [
        "/\\.github/workflows/.*\\.ya?ml$/",
        "/^Dockerfile$/"
      ],
      "matchStrings": [
        "#\\s+renovate:\\s+datasource=deb(?:\\s+distro=(?<distro>\\S+))?\\s+depName=(?<depName>\\S+)\\s+suite=(?<suite>\\S+)\\s+\\w+_\\w+:\\s+(?<currentValue>[^\\n]+)",
        "#\\s+renovate:\\s+datasource=deb(?:\\s+distro=(?<distro>\\S+))?\\s+depName=(?<depName>\\S+)\\s+suite=(?<suite>\\S+)\\s+ENV\\s+\\S+_VERSION=\"(?<currentValue>[^\"]+)\""
      ],
      "registryUrlTemplate": "https://{{#if (eq distro 'ubuntu')}}archive.ubuntu.com/ubuntu{{else}}deb.debian.org/debian{{/if}}?suite={{suite}}-updates&components=main,multiverse,restricted,universe&binaryArch=amd64"
    },
    {
      "customType": "regex",
      "datasourceTemplate": "deb",
      "managerFilePatterns": [
        "/\\.github/workflows/.*\\.ya?ml$/",
        "/^Dockerfile$/"
      ],
      "matchStrings": [
        "#\\s+renovate:\\s+datasource=deb(?:\\s+distro=(?<distro>\\S+))?\\s+depName=(?<depName>\\S+)\\s+suite=(?<suite>\\S+)\\s+\\w+_\\w+:\\s+(?<currentValue>[^\\n]+)",
        "#\\s+renovate:\\s+datasource=deb(?:\\s+distro=(?<distro>\\S+))?\\s+depName=(?<depName>\\S+)\\s+suite=(?<suite>\\S+)\\s+ENV\\s+\\S+_VERSION=\"(?<currentValue>[^\"]+)\""
      ],
      "registryUrlTemplate": "https://{{#if (eq distro 'ubuntu')}}security.ubuntu.com/ubuntu{{else}}security.debian.org/debian-security{{/if}}?suite={{suite}}-security&components=main,multiverse,restricted,universe&binaryArch=amd64"
    }
  ],
  "docker-compose": {
    "managerFilePatterns": [
      "/^src/(development/stack|production/production)\\.ya?ml$/"
    ]
  },
  "extends": [
    "config:best-practices",
    "group:allNonMajor",
    ":disableDependencyDashboard",
    ":semanticCommits",
    ":semanticCommitTypeAll(chore)",
    ":widenPeerDependencies"
  ],
  "git-submodules": {
    "enabled": true
  },
  "ignorePresets": ["docker:pinDigests", ":ignoreModulesAndTests"],
  "major": {
    "automerge": false
  },
  "packageRules": [
    {
      "major": {
        "enabled": true
      },
      "matchCategories": ["docker"]
    },
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": ["ghcr.io/observabilitystack/geoip-api"],
      "versioning": "regex:^(?<minor>\\d{4}-\\d{2})$"
    },
    {
      "matchDepTypes": ["dependencies"],
      "rangeStrategy": "update-lockfile"
    },
    {
      "groupName": "playwright monorepo",
      "matchPackageNames": [
        "@playwright/test",
        "mcr.microsoft.com/playwright",
        "playwright-core"
      ]
    },
    {
      "groupName": "@dargmuesli/nuxt-vio",
      "matchPackageNames": [
        "@dargmuesli/nuxt-vio",
        "@dargmuesli/nuxt-vio-testing"
      ]
    }
  ],
  "printConfig": true
}
