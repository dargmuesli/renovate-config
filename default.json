{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "automerge": true,
  "automergeType": "branch",
  "customManagers": [
    {
      "customType": "regex",
      "datasourceTemplate": "node",
      "depNameTemplate": "node",
      "managerFilePatterns": ["/^Dockerfile$/"],
      "matchStrings": ["FROM node:(?<currentValue>.*?)-(alpine|slim)\\n"],
      "versioningTemplate": "node"
    },
    {
      "customType": "regex",
      "datasourceTemplate": "deb",
      "managerFilePatterns": [
        "/\\.github/workflows/.*\\.ya?ml$/"
      ],
      "matchStrings": [
        "#\\s+renovate:\\s+datasource=deb\\s+depName=(?<depName>\\S+)\\s+suite=(?<suite>\\S+)\\s+\\w+_\\w+:\\s+(?<currentValue>[^\\n]+)"
      ],
      "registryUrlTemplate": "https://archive.ubuntu.com/ubuntu?suite={{#if suite }}{{suite}}{{else}}noble{{/if}}&components=main,multiverse,restricted,universe&binaryArch=amd64"
    },
    {
      "customType": "regex",
      "datasourceTemplate": "deb",
      "managerFilePatterns": [
        "/\\.github/workflows/.*\\.ya?ml$/"
      ],
      "matchStrings": [
        "#\\s+renovate:\\s+datasource=deb\\s+depName=(?<depName>\\S+)\\s+suite=(?<suite>\\S+)\\s+\\w+_\\w+:\\s+(?<currentValue>[^\\n]+)"
      ],
      "registryUrlTemplate": "https://archive.ubuntu.com/ubuntu?suite={{#if suite }}{{suite}}-updates{{else}}noble-updates{{/if}}&components=main,multiverse,restricted,universe&binaryArch=amd64"
    },
    {
      "customType": "regex",
      "datasourceTemplate": "deb",
      "managerFilePatterns": [
        "/\\.github/workflows/.*\\.ya?ml$/"
      ],
      "matchStrings": [
        "#\\s+renovate:\\s+datasource=deb\\s+depName=(?<depName>\\S+)\\s+suite=(?<suite>\\S+)\\s+\\w+_\\w+:\\s+(?<currentValue>[^\\n]+)"
      ],
      "registryUrlTemplate": "https://security.ubuntu.com/ubuntu?suite={{#if suite }}{{suite}}-security{{else}}noble-security{{/if}}&components=main,multiverse,restricted,universe&binaryArch=amd64"
    },
    {
      "customType": "regex",
      "datasourceTemplate": "deb",
      "managerFilePatterns": ["/^Dockerfile$/"],
      "matchStrings": [
        "#\\s*renovate:\\s*?(suite=(?<suite>.*?))?\\s*depName=(?<depName>.*?)?\\sENV .*?_VERSION=\"(?<currentValue>.*)\""
      ],
      "registryUrlTemplate": "https://deb.debian.org/debian?suite={{#if suite }}{{suite}}{{else}}stable{{/if}}&components=main,contrib,non-free&binaryArch=amd64"
    }
  ],
  "docker-compose": {
    "managerFilePatterns": [
      "/^src/(development/stack|production/production)\\.ya?ml$/"
    ]
  },
  "extends": [
    "config:best-practices",
    "group:allNonMajor",
    ":disableDependencyDashboard",
    ":semanticCommits",
    ":semanticCommitTypeAll(chore)",
    ":widenPeerDependencies"
  ],
  "git-submodules": {
    "enabled": true
  },
  "ignorePresets": ["docker:pinDigests", ":ignoreModulesAndTests"],
  "major": {
    "automerge": false
  },
  "packageRules": [
    {
      "major": {
        "enabled": true
      },
      "matchCategories": ["docker"]
    },
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": ["ghcr.io/observabilitystack/geoip-api"],
      "versioning": "regex:^(?<minor>\\d{4}-\\d{2})$"
    },
    {
      "matchDepTypes": ["dependencies"],
      "rangeStrategy": "update-lockfile"
    },
    {
      "groupName": "playwright monorepo",
      "matchPackageNames": [
        "@playwright/test",
        "mcr.microsoft.com/playwright",
        "playwright-core"
      ]
    },
    {
      "groupName": "@dargmuesli/nuxt-vio",
      "matchPackageNames": [
        "@dargmuesli/nuxt-vio",
        "@dargmuesli/nuxt-vio-testing"
      ]
    }
  ],
  "printConfig": true
}
